<ContentDialog
    x:Class="ExtrabbitCode.Inventor.MetaReader.App.AboutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">760</x:Double>
        <x:Double x:Key="ContentDialogMinWidth">560</x:Double>
    </ContentDialog.Resources>

    <Grid Width="660" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header: icon + name/description/version  |  ExtrabbitCode logo -->
        <Grid Grid.Row="0" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="ms-appx:///Assets/inventor-meta-128.png"
                   Width="64" Height="64" VerticalAlignment="Top"/>
            <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock x:Name="NameText" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap"/>
                <TextBlock x:Name="DescText" Opacity="0.8" TextWrapping="Wrap"/>
                <TextBlock x:Name="VersionText" FontWeight="SemiBold" Margin="0,4,0,0"/>
            </StackPanel>
            <HyperlinkButton Grid.Column="2" x:Name="ExtrabbitButton" Padding="0"
                             VerticalAlignment="Top" ToolTipService.ToolTip="extrabbitcode.com">
                <Image Source="ms-appx:///Assets/extrabbit.png" Height="48" Stretch="Uniform"/>
            </HyperlinkButton>
        </Grid>

        <!-- link buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">
            <HyperlinkButton x:Name="DocsButton" NavigateUri="https://example.invalid">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8A5;" FontSize="14"/>
                    <TextBlock Text="Documentation"/>
                </StackPanel>
            </HyperlinkButton>
            <HyperlinkButton x:Name="GitHubButton" NavigateUri="https://example.invalid">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Viewbox Width="16" Height="16">
                        <Path Fill="{ThemeResource TextFillColorPrimaryBrush}"
                              Data="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.26.82-.577 0-.285-.01-1.04-.015-2.04-3.338.726-4.043-1.61-4.043-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.085 1.84 1.237 1.84 1.237 1.07 1.835 2.807 1.305 3.492.998.108-.776.42-1.305.763-1.605-2.665-.305-5.467-1.335-5.467-5.93 0-1.31.467-2.38 1.235-3.22-.123-.303-.535-1.523.117-3.176 0 0 1.008-.323 3.3 1.23a11.5 11.5 0 0 1 3.003-.404c1.02.005 2.047.138 3.006.404 2.29-1.553 3.297-1.23 3.297-1.23.653 1.653.242 2.873.118 3.176.77.84 1.233 1.91 1.233 3.22 0 4.61-2.807 5.62-5.48 5.92.43.37.823 1.103.823 2.223 0 1.604-.015 2.898-.015 3.293 0 .32.217.694.825.576C20.565 22.296 24 17.798 24 12.5 24 5.87 18.627.5 12 .5z"/>
                    </Viewbox>
                    <TextBlock Text="GitHub Repository"/>
                </StackPanel>
            </HyperlinkButton>
        </StackPanel>

        <!-- version history -->
        <StackPanel Grid.Row="2" Spacing="8">
            <TextBlock Text="Version History" FontWeight="SemiBold" FontSize="15"/>
            <Border CornerRadius="6" Padding="14" MinHeight="120"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel x:Name="HistoryPanel" Spacing="10"/>
            </Border>
        </StackPanel>

        <!-- open-source notices (LGPL attribution for the STEP importer, and friends) -->
        <StackPanel Grid.Row="3" Spacing="8">
            <TextBlock Text="Open-Source Notices" FontWeight="SemiBold" FontSize="15"/>
            <Border CornerRadius="6" Padding="14"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock TextWrapping="Wrap" Opacity="0.85" FontSize="12"
                               Text="STEP viewing is powered by occt-import-js 0.0.23 and Open CASCADE Technology (OCCT), used unmodified under the GNU LGPL v2.1. They ship as separate, user-replaceable WebAssembly module files in Assets\stepviewer\vendor."/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12"
                               Text="The reference graph uses vis-network 9.1.9 (MIT / Apache-2.0). The 3D view loads the Autodesk Viewer from Autodesk's CDN under Autodesk's terms of service."/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <HyperlinkButton Content="occt-import-js source" FontSize="12" Padding="2"
                                         NavigateUri="https://github.com/kovacsv/occt-import-js"/>
                        <HyperlinkButton Content="OCCT source" FontSize="12" Padding="2"
                                         NavigateUri="https://github.com/Open-Cascade-SAS/OCCT"/>
                        <HyperlinkButton x:Name="LgplButton" Content="LGPL-2.1 license text" FontSize="12" Padding="2"
                                         Click="OnShowLgplLicense"/>
                        <HyperlinkButton x:Name="NoticesButton" Content="All notices" FontSize="12" Padding="2"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</ContentDialog>
