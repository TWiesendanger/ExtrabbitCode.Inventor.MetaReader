<Window
    x:Class="ExtrabbitCode.Inventor.MetaReader.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <!-- KeyboardAcceleratorPlacementMode=Hidden: the Ctrl+W accelerator is window-wide (owned by the
         root grid), but its automatic tooltip would otherwise pop over every area without its own
         tooltip - the empty Reference-graph canvas in particular. We surface the hint only on the tab. -->
    <Grid Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
          KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="W" Invoked="OnCloseTabShortcut"/>
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar row: a draggable strip (icon + title) plus an interactive theme toggle -->
        <Grid Grid.Row="0" Height="48"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="138"/> <!-- reserve space under the min/max/close buttons -->
            </Grid.ColumnDefinitions>

            <!-- drag region -->
            <Grid x:Name="AppTitleBar" Grid.Column="0" Padding="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="ms-appx:///Assets/inventor-meta-48.png"
                       Width="24" Height="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Inventor MetaReader" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="VersionText" FontSize="11" Opacity="0.5" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Read .ipt / .iam / .idw / .ipn without Autodesk Inventor"
                               FontSize="11" Opacity="0.6" Margin="0,-2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- theme toggle (light / dark) -->
            <Button x:Name="ThemeButton" Grid.Column="1" Click="OnThemeButtonClick"
                    VerticalAlignment="Center" Margin="0,0,10,0" Padding="9,6"
                    Background="Transparent" BorderThickness="0">
                <FontIcon x:Name="ThemeIcon" FontSize="16"/>
            </Button>
        </Grid>

        <!-- Body: document tabs + empty-state drop zone -->
        <Grid Grid.Row="1" AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop">
            <muxc:TabView x:Name="DocTabs"
                          AddTabButtonClick="OnAddTab"
                          TabCloseRequested="OnTabClose"
                          SelectionChanged="OnTabSelectionChanged"
                          CanReorderTabs="True" TabWidthMode="SizeToContent"
                          VerticalAlignment="Stretch"/>

            <!-- shown when no documents are open -->
            <Grid x:Name="EmptyState" Padding="48" AllowDrop="True" DragOver="OnDragOver" Drop="OnDrop">
                <Border MaxWidth="640" MaxHeight="460" CornerRadius="16" Translation="0,0,32"
                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultSolidBrush}">
                    <Border.Shadow><ThemeShadow/></Border.Shadow>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{ThemeResource CardBackgroundFillColorDefault}" Offset="0"/>
                            <GradientStop Color="{ThemeResource CardBackgroundFillColorSecondary}" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20" Padding="32">

                        <!-- supported-type icon row -->
                        <StackPanel Orientation="Horizontal" Spacing="22" HorizontalAlignment="Center">
                            <StackPanel Spacing="6" Width="74">
                                <Border CornerRadius="14" Padding="14" HorizontalAlignment="Center"
                                        Background="{ThemeResource SmokeFillColorDefaultBrush}">
                                    <Image Source="ms-appx:///Assets/part.png" Width="40" Height="40"/>
                                </Border>
                                <TextBlock Text="Part" FontSize="12" Opacity="0.75" HorizontalAlignment="Center"/>
                                <TextBlock Text=".ipt" FontFamily="Consolas" FontSize="11" Opacity="0.45" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Spacing="6" Width="74">
                                <Border CornerRadius="14" Padding="14" HorizontalAlignment="Center"
                                        Background="{ThemeResource SmokeFillColorDefaultBrush}">
                                    <Image Source="ms-appx:///Assets/assembly.png" Width="40" Height="40"/>
                                </Border>
                                <TextBlock Text="Assembly" FontSize="12" Opacity="0.75" HorizontalAlignment="Center"/>
                                <TextBlock Text=".iam" FontFamily="Consolas" FontSize="11" Opacity="0.45" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Spacing="6" Width="74">
                                <Border CornerRadius="14" Padding="14" HorizontalAlignment="Center"
                                        Background="{ThemeResource SmokeFillColorDefaultBrush}">
                                    <Image Source="ms-appx:///Assets/drawing.png" Width="40" Height="40"/>
                                </Border>
                                <TextBlock Text="Drawing" FontSize="12" Opacity="0.75" HorizontalAlignment="Center"/>
                                <TextBlock Text=".idw" FontFamily="Consolas" FontSize="11" Opacity="0.45" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Spacing="6" Width="74">
                                <Border CornerRadius="14" Padding="14" HorizontalAlignment="Center"
                                        Background="{ThemeResource SmokeFillColorDefaultBrush}">
                                    <Image Source="ms-appx:///Assets/presentation.png" Width="40" Height="40"/>
                                </Border>
                                <TextBlock Text="Presentation" FontSize="12" Opacity="0.75" HorizontalAlignment="Center"/>
                                <TextBlock Text=".ipn" FontFamily="Consolas" FontSize="11" Opacity="0.45" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="6" Margin="0,8,0,0">
                            <TextBlock Text="Drag &amp; drop Inventor files here"
                                       FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Drop several at once - each opens in its own tab. No Autodesk Inventor required."
                                       FontSize="13" Opacity="0.7" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center" MaxWidth="440"/>
                        </StackPanel>

                        <Button x:Name="BrowseButton" Click="OnOpenClick" HorizontalAlignment="Center"
                                Style="{ThemeResource AccentButtonStyle}" Padding="20,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8E5;" FontSize="14"/>
                                <TextBlock Text="Browse files…"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- top-right anchor so the welcome tip sits in the corner, not over the centred card -->
            <Border x:Name="WelcomeAnchor" Width="1" Height="1" IsHitTestVisible="False"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,18,0"/>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" Padding="20,8" ColumnSpacing="12"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Grid.Column="0" VerticalAlignment="Center" Opacity="0.7"
                       FontSize="12" Text="Ready. Open or drop an Inventor file to begin."/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Click="OnSettingsClick" ToolTipService.ToolTip="Settings">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE713;" FontSize="14"/>
                        <TextBlock Text="Settings"/>
                    </StackPanel>
                </Button>
                <Button Click="OnInfoClick" ToolTipService.ToolTip="About">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE946;" FontSize="14"/>
                        <TextBlock Text="About"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- fullscreen overlay host (e.g. the reference graph blown up to fill the window) -->
        <Grid x:Name="OverlayHost" Grid.RowSpan="3" Visibility="Collapsed"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"/>

        <!-- in-app toast (copy confirmations, etc.) -->
        <Border x:Name="Toast" Grid.RowSpan="3" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,56" Padding="16,10" CornerRadius="8" Translation="0,0,48"
                Visibility="Collapsed" Opacity="0"
                Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultSolidBrush}" BorderThickness="1">
            <Border.Shadow><ThemeShadow/></Border.Shadow>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon Glyph="&#xE73E;" FontSize="14"
                          Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                <TextBlock x:Name="ToastText" VerticalAlignment="Center" FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
