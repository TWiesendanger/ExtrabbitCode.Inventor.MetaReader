<UserControl
    x:Class="InventorMeta.App.DocumentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <UserControl.Resources>
        <!-- theme-reactive styles for the code-built cards & tables -->
        <!-- active-tab background: a theme-reactive card colour so the selected tab stands out -->
        <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="{ThemeResource SolidBackgroundFillColorTertiary}"/>

        <Style x:Key="DataCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultSolidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <!-- mid layer: a container surface that the data cards sit on -->
        <Style x:Key="Surface" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultSolidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style x:Key="CardHeaderRow" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="CornerRadius" Value="8,8,0,0"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>
        <!-- thin divider line between table rows -->
        <Style x:Key="RowLine" TargetType="Border">
            <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource AccentFillColorDefaultBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,1,8,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BadgeText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- per-document command bar -->
        <Grid Grid.Row="0" Padding="16,10" ColumnSpacing="10"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <FontIcon Grid.Column="0" Glyph="&#xE8A5;" FontSize="16" VerticalAlignment="Center"/>
            <TextBlock x:Name="PathText" Grid.Column="1" Margin="6,0" VerticalAlignment="Center"
                       FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis"
                       IsTextSelectionEnabled="True"/>
            <Button x:Name="HiddenButton" Grid.Column="2" Visibility="Collapsed"
                    ToolTipService.ToolTip="Hidden items - click to manage"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}">
                <Button.Flyout>
                    <Flyout x:Name="HiddenFlyout" Placement="Bottom">
                        <StackPanel x:Name="HiddenFlyoutPanel" MinWidth="260" Spacing="2"/>
                    </Flyout>
                </Button.Flyout>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE7B3;" FontSize="14"/>
                    <TextBlock x:Name="HiddenCountText"/>
                </StackPanel>
            </Button>
            <Button x:Name="RefreshButton" Grid.Column="3" Click="OnRefresh" ToolTipService.ToolTip="Reload from disk">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="Refresh"/>
                </StackPanel>
            </Button>
            <Button x:Name="ExportButton" Grid.Column="4" Click="OnExportJson" ToolTipService.ToolTip="Export metadata as JSON">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                    <TextBlock Text="Export JSON"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- body: left card + right detail tabs -->
        <Grid Grid.Row="1" Padding="16" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="8" Translation="0,0,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultSolidBrush}" BorderThickness="1">
                <Border.Shadow><ThemeShadow/></Border.Shadow>
                <ScrollViewer>
                    <StackPanel>
                        <!-- preview fills the top of the card edge-to-edge -->
                        <Border x:Name="ThumbHost" Height="264" CornerRadius="8,8,0,0">
                            <Border.Background>
                                <ImageBrush x:Name="ThumbBrush" Stretch="UniformToFill"/>
                            </Border.Background>
                            <TextBlock x:Name="NoThumb" Text="No preview" Opacity="0.5"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Border>
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <Grid Padding="16,12,16,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image x:Name="TypeIcon" Grid.Column="0" Width="36" Height="36"
                                   VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="FileNameText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="DocTypeText" Opacity="0.7" FontSize="13" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel x:Name="KeyPropsPanel" Padding="16,4,16,16" Spacing="8"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Surface}" Translation="0,0,16">
                <Border.Shadow><ThemeShadow/></Border.Shadow>
                <muxc:TabView x:Name="DetailTabs" Background="Transparent" IsAddTabButtonVisible="False"
                              CanReorderTabs="False" CanDragTabs="False">
                    <muxc:TabViewItem x:Name="PropsTab" Header="All Properties" IsClosable="False">
                        <muxc:TabViewItem.IconSource><muxc:SymbolIconSource Symbol="AllApps"/></muxc:TabViewItem.IconSource>
                        <ScrollViewer Padding="10,10"><StackPanel x:Name="PropsPanel" Spacing="10"/></ScrollViewer>
                    </muxc:TabViewItem>
                    <muxc:TabViewItem x:Name="StatesTab" Header="Model States" IsClosable="False">
                        <muxc:TabViewItem.IconSource><muxc:SymbolIconSource Symbol="Switch"/></muxc:TabViewItem.IconSource>
                        <ScrollViewer Padding="10,10"><StackPanel x:Name="StatesPanel" Spacing="12"/></ScrollViewer>
                    </muxc:TabViewItem>
                    <muxc:TabViewItem x:Name="RefsTab" Header="References" IsClosable="False">
                        <muxc:TabViewItem.IconSource><muxc:SymbolIconSource Symbol="Link"/></muxc:TabViewItem.IconSource>
                        <ScrollViewer Padding="14"><StackPanel x:Name="RefsPanel" Spacing="12"/></ScrollViewer>
                    </muxc:TabViewItem>
                    <muxc:TabViewItem x:Name="StructureTab" Header="File Structure" IsClosable="False">
                        <muxc:TabViewItem.IconSource><muxc:SymbolIconSource Symbol="List"/></muxc:TabViewItem.IconSource>
                        <ScrollViewer Padding="14"><TextBlock x:Name="TreeText" FontFamily="Consolas" IsTextSelectionEnabled="True"/></ScrollViewer>
                    </muxc:TabViewItem>
                </muxc:TabView>
            </Border>
        </Grid>
    </Grid>
</UserControl>
