<UserControl
    x:Class="InventorMeta.App.DocumentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- per-document command bar -->
        <Grid Grid.Row="0" Padding="16,10" ColumnSpacing="10"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <FontIcon Grid.Column="0" Glyph="&#xE8A5;" FontSize="16" VerticalAlignment="Center"/>
            <TextBlock x:Name="PathText" Grid.Column="1" Margin="6,0" VerticalAlignment="Center"
                       FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis"
                       IsTextSelectionEnabled="True"/>
            <Button x:Name="RefreshButton" Grid.Column="2" Click="OnRefresh" ToolTipService.ToolTip="Reload from disk">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="Refresh"/>
                </StackPanel>
            </Button>
            <Button x:Name="ExportButton" Grid.Column="3" Click="OnExportJson" ToolTipService.ToolTip="Export metadata as JSON">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                    <TextBlock Text="Export JSON"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- body: left card + right detail tabs -->
        <Grid Grid.Row="1" Padding="16" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <ScrollViewer>
                    <StackPanel>
                        <Grid Height="280" Background="{ThemeResource SmokeFillColorDefaultBrush}"
                              CornerRadius="8,8,0,0">
                            <Image x:Name="ThumbImage" Stretch="Uniform" Margin="12"/>
                            <TextBlock x:Name="NoThumb" Text="No preview" Opacity="0.5"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <Grid Padding="16,12,16,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image x:Name="TypeIcon" Grid.Column="0" Width="36" Height="36"
                                   VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="FileNameText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="DocTypeText" Opacity="0.7" FontSize="13" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel x:Name="KeyPropsPanel" Padding="16,4,16,16" Spacing="8"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <muxc:TabView Grid.Column="1" IsAddTabButtonVisible="False"
                          CanReorderTabs="False" CanDragTabs="False">
                <muxc:TabViewItem Header="All Properties" IsClosable="False">
                    <muxc:TabViewItem.IconSource><muxc:SymbolIconSource Symbol="AllApps"/></muxc:TabViewItem.IconSource>
                    <ScrollViewer Padding="4,8"><StackPanel x:Name="PropsPanel" Spacing="8"/></ScrollViewer>
                </muxc:TabViewItem>
                <muxc:TabViewItem x:Name="StatesTab" Header="Model States" IsClosable="False">
                    <muxc:TabViewItem.IconSource><muxc:SymbolIconSource Symbol="Switch"/></muxc:TabViewItem.IconSource>
                    <ScrollViewer Padding="8"><StackPanel x:Name="StatesPanel" Spacing="12"/></ScrollViewer>
                </muxc:TabViewItem>
                <muxc:TabViewItem Header="References" IsClosable="False">
                    <muxc:TabViewItem.IconSource><muxc:SymbolIconSource Symbol="Link"/></muxc:TabViewItem.IconSource>
                    <ScrollViewer Padding="8"><StackPanel x:Name="RefsPanel" Spacing="12"/></ScrollViewer>
                </muxc:TabViewItem>
                <muxc:TabViewItem Header="File Structure" IsClosable="False">
                    <muxc:TabViewItem.IconSource><muxc:SymbolIconSource Symbol="List"/></muxc:TabViewItem.IconSource>
                    <ScrollViewer Padding="8"><TextBlock x:Name="TreeText" FontFamily="Consolas" IsTextSelectionEnabled="True"/></ScrollViewer>
                </muxc:TabViewItem>
            </muxc:TabView>
        </Grid>
    </Grid>
</UserControl>
