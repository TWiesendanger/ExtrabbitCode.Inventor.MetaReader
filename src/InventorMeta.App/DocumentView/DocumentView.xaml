<UserControl
    x:Class="ExtrabbitCode.Inventor.MetaReader.App.DocumentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <UserControl.Resources>
        <!-- theme-reactive styles for the code-built cards & tables -->

        <!-- Detail tabs: the strip sits on the Tertiary surface, so the active tab must differ from it.
             Active = card colour + accent text; inactive = transparent + muted text. -->
        <SolidColorBrush x:Key="TabViewItemHeaderBackground" Color="Transparent"/>
        <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelected" Color="{ThemeResource CardBackgroundFillColorDefault}"/>
        <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelectedPointerOver" Color="{ThemeResource CardBackgroundFillColorSecondary}"/>
        <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelectedPressed" Color="{ThemeResource CardBackgroundFillColorDefault}"/>
        <SolidColorBrush x:Key="TabViewItemHeaderForeground" Color="{ThemeResource TextFillColorSecondary}"/>
        <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelected" Color="{ThemeResource TextFillColorPrimary}"/>
        <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelectedPointerOver" Color="{ThemeResource TextFillColorPrimary}"/>
        <SolidColorBrush x:Key="TabViewItemHeaderForegroundSelectedPressed" Color="{ThemeResource TextFillColorPrimary}"/>

        <Style x:Key="DataCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultSolidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <!-- mid layer: a container surface that the data cards sit on -->
        <Style x:Key="Surface" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource SolidBackgroundFillColorTertiaryBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultSolidBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style x:Key="CardHeaderRow" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="CornerRadius" Value="8,8,0,0"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>
        <!-- thin divider line between table rows -->
        <Style x:Key="RowLine" TargetType="Border">
            <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource AccentFillColorDefaultBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,1,8,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BadgeText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- per-document command bar -->
        <Grid Grid.Row="0" Padding="16,10" ColumnSpacing="6"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <FontIcon Grid.Column="0" Glyph="&#xE8A5;" FontSize="16" VerticalAlignment="Center"/>
            <!-- 3D: only when the sidebar thumbnail is off (otherwise the thumbnail is the trigger) -->
            <Button x:Name="View3DButton" Grid.Column="1" Click="OnOpen3D" Visibility="Collapsed"
                    Margin="6,0,0,0" ToolTipService.ToolTip="View the 3D model"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}">
                <FontIcon Glyph="&#xF158;" FontSize="14"/>
            </Button>
            <TextBlock x:Name="PathText" Grid.Column="2" Margin="6,0" VerticalAlignment="Center"
                       FontSize="12" Opacity="0.7" TextTrimming="CharacterEllipsis"
                       IsTextSelectionEnabled="True"/>
            <Button x:Name="ExplorerButton" Grid.Column="3" Click="OnShowInExplorer"
                    ToolTipService.ToolTip="Show this file in File Explorer">
                <FontIcon Glyph="&#xEC50;" FontSize="14"/>
            </Button>
            <Button x:Name="HiddenButton" Grid.Column="4" Visibility="Collapsed" Click="OnHiddenButtonClick"
                    ToolTipService.ToolTip="Hidden items - click to manage"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE7B3;" FontSize="14"/>
                    <TextBlock x:Name="HiddenCountText"/>
                </StackPanel>
            </Button>
            <Button x:Name="RefreshButton" Grid.Column="5" Click="OnRefresh" ToolTipService.ToolTip="Reload from disk">
                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
            </Button>
            <Button x:Name="ExportButton" Grid.Column="6" Click="OnExportJson" ToolTipService.ToolTip="Export metadata as JSON">
                <FontIcon Glyph="&#xE74E;" FontSize="14"/>
            </Button>
        </Grid>

        <!-- body: left card + right detail tabs -->
        <Grid Grid.Row="1" Padding="16" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarCard" Grid.Column="0" CornerRadius="8" Translation="0,0,12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultSolidBrush}" BorderThickness="1">
                <Border.Shadow><ThemeShadow/></Border.Shadow>
                <ScrollViewer>
                    <StackPanel>
                        <!-- preview fills the top of the card edge-to-edge -->
                        <Border x:Name="ThumbHost" Height="264" CornerRadius="8,8,0,0" Tapped="OnThumbTapped">
                            <Border.Background>
                                <ImageBrush x:Name="ThumbBrush" Stretch="UniformToFill"/>
                            </Border.Background>
                            <Grid>
                                <TextBlock x:Name="NoThumb" Text="No preview" Opacity="0.5"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                <!-- hint that the preview opens the 3D viewer (Part/Assembly only) -->
                                <Border x:Name="ThreeDHint" VerticalAlignment="Bottom" Visibility="Collapsed"
                                        Background="#99000000" Padding="0,6">
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                        <FontIcon Glyph="&#xF158;" FontSize="13" Foreground="White"/>
                                        <TextBlock Text="Click to view in 3D" FontSize="12" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                        <Border x:Name="ThumbDivider" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <Grid Padding="16,12,16,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Image x:Name="TypeIcon" Grid.Column="0" Width="36" Height="36"
                                   VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="FileNameText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="DocTypeText" Opacity="0.7" FontSize="13" TextWrapping="Wrap"/>
                                <!-- colour-coded document category; hover shows the legend (set in code) -->
                                <Border x:Name="CategoryBadge" Margin="0,7,0,1" CornerRadius="10" Padding="10,2,10,3"
                                        HorizontalAlignment="Left" Visibility="Collapsed">
                                    <TextBlock x:Name="CategoryBadgeText" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                                <!-- stale segment summaries: Inventor refuses such files; the button repairs in place -->
                                <StackPanel x:Name="DamagePanel" Orientation="Horizontal" Spacing="8" Margin="0,7,0,1"
                                            Visibility="Collapsed">
                                    <Border x:Name="DamageBadge" CornerRadius="10" Padding="10,2,10,3"
                                            VerticalAlignment="Center" Background="#C42B1C">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <FontIcon Glyph="&#xE7BA;" FontSize="11" Foreground="White" VerticalAlignment="Center"/>
                                            <TextBlock Text="Damaged file" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                    <Button x:Name="RepairButton" Click="OnRepairSegments" MinWidth="0" Padding="8,1,8,2"
                                            VerticalAlignment="Center" ToolTipService.ToolTip="Fix the segment summaries in place (a backup copy is created first)">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <FontIcon Glyph="&#xE90F;" FontSize="11"/>
                                            <TextBlock Text="Repair" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <!-- after a successful repair: confirmation + a shortcut to verify in Inventor itself -->
                                <StackPanel x:Name="RepairedPanel" Orientation="Horizontal" Spacing="8" Margin="0,7,0,1"
                                            Visibility="Collapsed">
                                    <Border CornerRadius="10" Padding="10,2,10,3" VerticalAlignment="Center" Background="#15803D">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <FontIcon Glyph="&#xE73E;" FontSize="11" Foreground="White" VerticalAlignment="Center"/>
                                            <TextBlock Text="Repaired" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                    <Button x:Name="OpenInInventorButton" Click="OnOpenInInventor" MinWidth="0" Padding="8,1,8,2"
                                            VerticalAlignment="Center" ToolTipService.ToolTip="Open the repaired file in Autodesk Inventor to verify it loads cleanly">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <FontIcon Glyph="&#xE8A7;" FontSize="11"/>
                                            <TextBlock Text="Open in Inventor" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                            <ToggleButton x:Name="EditSidebarToggle" Grid.Column="2" VerticalAlignment="Top"
                                          Click="OnToggleSidebarEdit" Padding="7,5" MinWidth="0"
                                          ToolTipService.ToolTip="Customize sidebar">
                                <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                            </ToggleButton>
                        </Grid>
                        <StackPanel x:Name="SidebarEditPanel" Padding="16,4,16,0" Spacing="8"/>
                        <StackPanel x:Name="KeyPropsPanel" Padding="16,4,16,8" Spacing="8"/>
                        <StackPanel x:Name="SidebarAddPanel" Padding="16,0,16,16" Spacing="8"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Surface}" Translation="0,0,16">
                <Border.Shadow><ThemeShadow/></Border.Shadow>
                <!-- Stretch to fill the card; the TabView defaults to Top / content-sized. -->
                <muxc:TabView x:Name="DetailTabs" Background="Transparent" IsAddTabButtonVisible="False"
                              CanReorderTabs="False" CanDragTabs="False" VerticalAlignment="Stretch"
                              SelectionChanged="OnDetailTabChanged">
                    <muxc:TabView.TabStripFooter>
                        <StackPanel x:Name="TabStripActions" Orientation="Horizontal"
                                    VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                    </muxc:TabView.TabStripFooter>
                    <muxc:TabViewItem x:Name="PropsTab" Header="All Properties" IsClosable="False">
                        <muxc:TabViewItem.IconSource><muxc:SymbolIconSource Symbol="AllApps"/></muxc:TabViewItem.IconSource>
                        <ScrollViewer Padding="10,10"><StackPanel x:Name="PropsPanel" Spacing="10"/></ScrollViewer>
                    </muxc:TabViewItem>
                    <muxc:TabViewItem x:Name="StatesTab" Header="Model States" IsClosable="False">
                        <muxc:TabViewItem.IconSource><muxc:SymbolIconSource Symbol="Switch"/></muxc:TabViewItem.IconSource>
                        <ScrollViewer Padding="10,10"><StackPanel x:Name="StatesPanel" Spacing="12"/></ScrollViewer>
                    </muxc:TabViewItem>
                    <muxc:TabViewItem x:Name="RefsTab" Header="References" IsClosable="False">
                        <muxc:TabViewItem.IconSource><muxc:SymbolIconSource Symbol="Link"/></muxc:TabViewItem.IconSource>
                        <Grid x:Name="RefsRoot"/>
                    </muxc:TabViewItem>
                    <muxc:TabViewItem x:Name="StructureTab" Header="File Structure" IsClosable="False">
                        <muxc:TabViewItem.IconSource><muxc:SymbolIconSource Symbol="List"/></muxc:TabViewItem.IconSource>
                        <ScrollViewer Padding="10,10">
                            <!-- Inventor files get the segment-database card + storage tree (built in code);
                                 STEP files show their source text in the plain TextBlock instead. -->
                            <StackPanel x:Name="StructurePanel" Spacing="10">
                                <TextBlock x:Name="TreeText" FontFamily="Consolas" IsTextSelectionEnabled="True"
                                           Visibility="Collapsed" Margin="4"/>
                            </StackPanel>
                        </ScrollViewer>
                    </muxc:TabViewItem>
                </muxc:TabView>
            </Border>
        </Grid>
    </Grid>
</UserControl>
